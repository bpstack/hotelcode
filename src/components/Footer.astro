  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <span class="text-sm font-bold text-white dark:text-dark-text">Hotel<span class="text-accent-400">Code</span></span>
        <span class="text-sm">&copy; {year} Salvador Pérez</span>
      </div>
      <div class="flex items-center gap-6 text-sm">
        <a href="https://four-points.stackbp.es" target="_blank" rel="noopener noreferrer" class="hover:text-white dark:hover:text-dark-text transition-colors">
          Four Points Demo
        </a>
        <a href="https://github.com/bpstack" target="_blank" rel="noopener noreferrer" class="hover:text-white dark:hover:text-dark-text transition-colors">
