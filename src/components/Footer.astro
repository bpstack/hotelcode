---
const year = new Date().getFullYear();
---

<!-- CTA Banner -->
<section class="py-24 sm:py-32 bg-white dark:bg-dark-bg relative overflow-hidden">
  <div class="absolute inset-0">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[400px] bg-brand-500/[0.06] dark:bg-brand-500/[0.03] rounded-full blur-[120px]"></div>
  </div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div data-glow class="reveal relative p-10 sm:p-14 rounded-3xl border border-surface-200/60 dark:border-dark-border/60 bg-gradient-to-br from-brand-50 via-white to-surface-50 dark:from-dark-layer1 dark:via-dark-layer1 dark:to-dark-layer2 shadow-xl shadow-surface-900/[0.04] dark:shadow-black/10 overflow-hidden text-center">
      <!-- Decorative gradient circles -->
      <div class="absolute top-0 right-0 w-40 h-40 bg-brand-500/10 dark:bg-brand-500/5 rounded-full blur-[60px]"></div>
      <div class="absolute bottom-0 left-0 w-32 h-32 bg-accent-400/10 dark:bg-accent-400/5 rounded-full blur-[50px]"></div>

      <div class="relative">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-surface-900 dark:text-dark-text leading-tight mb-4">
          ¿Listo para ver <br class="hidden sm:block" />
          <span class="bg-gradient-to-r from-brand-500 to-brand-700 dark:from-brand-300 dark:to-brand-500 bg-clip-text text-transparent">Four Points en acción?</span>
        </h2>
        <p class="text-surface-500 dark:text-dark-text2 text-lg max-w-xl mx-auto mb-8">
          Explora la demo live del PMS que automatiza las operaciones de un hotel real.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="https://four-points.stackbp.es"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-shine group inline-flex items-center justify-center gap-2 px-7 py-3.5 text-base font-semibold text-white bg-gradient-to-r from-brand-600 to-brand-700 rounded-2xl hover:from-brand-500 hover:to-brand-600 shadow-xl shadow-brand-600/20 hover:shadow-brand-500/30 transition-all duration-300 hover:-translate-y-0.5"
          >
            Ver demo live
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a
            href="https://github.com/bpstack"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-7 py-3.5 text-base font-semibold text-surface-700 dark:text-brand-200 bg-white dark:bg-brand-950/60 border border-surface-200 dark:border-brand-600/40 rounded-2xl hover:bg-surface-50 dark:hover:bg-brand-900/60 hover:border-surface-300 dark:hover:border-brand-500/60 shadow-md shadow-surface-900/5 dark:shadow-brand-900/20 transition-all duration-300 hover:-translate-y-0.5"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="relative bg-surface-900 dark:bg-dark-bg border-t border-surface-800 dark:border-brand-900/40 overflow-hidden [background:theme(colors.surface.900)] dark:[background:linear-gradient(to_top,_#2e1065_0%,_#0d0a1e_35%,_#09090f_60%)]">
  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Main footer content -->
    <div class="py-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center shadow-md shadow-brand-500/20">
            <span class="text-white text-xs font-bold">HC</span>
          </div>
          <span class="text-lg font-bold text-white">
            Hotel<span class="text-brand-400">Code</span>
          </span>
        </a>
        <p class="text-sm text-surface-400 dark:text-white/50 leading-relaxed mb-6 max-w-xs">
          De hotelero a developer: documentando la construcción de un PMS completo con +14 módulos.
        </p>
        <!-- Social links -->
        <div class="flex items-center gap-3">
          <a href="https://github.com/bpstack" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-surface-800 dark:bg-brand-900/40 border dark:border-brand-700/30 flex items-center justify-center text-surface-400 dark:text-white/60 hover:text-white dark:hover:text-white hover:bg-surface-700 dark:hover:bg-brand-700/50 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="https://stackbp.es" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-surface-800 dark:bg-brand-900/40 border dark:border-brand-700/30 flex items-center justify-center text-surface-400 dark:text-white/60 hover:text-white dark:hover:text-white hover:bg-surface-700 dark:hover:bg-brand-700/50 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="text-sm font-bold text-white dark:text-white mb-4 uppercase tracking-wider">Navegación</h4>
        <ul class="space-y-3">
          <li><a href="#proyecto" class="text-sm text-surface-400 dark:text-white/50 hover:text-white dark:hover:text-white transition-colors">Proyecto</a></li>
          <li><a href="#modulos" class="text-sm text-surface-400 dark:text-white/50 hover:text-white dark:hover:text-white transition-colors">Módulos</a></li>
          <li><a href="#tech" class="text-sm text-surface-400 dark:text-white/50 hover:text-white dark:hover:text-white transition-colors">Tech Stack</a></li>
          <li><a href="#sobre-mi" class="text-sm text-surface-400 dark:text-white/50 hover:text-white dark:hover:text-white transition-colors">Sobre mí</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-sm font-bold text-white dark:text-white mb-4 uppercase tracking-wider">Recursos</h4>
        <ul class="space-y-3">
          <li><a href="https://four-points.stackbp.es" target="_blank" rel="noopener noreferrer" class="text-sm text-surface-400 dark:text-white/50 hover:text-white dark:hover:text-white transition-colors">Four Points Demo</a></li>
          <li><a href="https://github.com/bpstack" target="_blank" rel="noopener noreferrer" class="text-sm text-surface-400 dark:text-white/50 hover:text-white dark:hover:text-white transition-colors">GitHub</a></li>
          <li><a href="https://stackbp.es" target="_blank" rel="noopener noreferrer" class="text-sm text-surface-400 dark:text-white/50 hover:text-white dark:hover:text-white transition-colors">StackBP Portfolio</a></li>
        </ul>
      </div>

      <!-- Tech used -->
      <div>
        <h4 class="text-sm font-bold text-white dark:text-white mb-4 uppercase tracking-wider">Hecho con</h4>
        <ul class="space-y-3">
          <li class="text-sm text-surface-400 dark:text-white/50">Astro 5</li>
          <li class="text-sm text-surface-400 dark:text-white/50">Tailwind CSS v4</li>
          <li class="text-sm text-surface-400 dark:text-white/50">Vercel</li>
          <li class="text-sm text-surface-400 dark:text-white/50">Cloudinary</li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="py-6 border-t border-surface-800 dark:border-brand-900/40 flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="text-xs text-surface-500 dark:text-white/30">
        &copy; {year} Salvador Pérez. Todos los derechos reservados.
      </span>
    </div>
  </div>
</footer>
