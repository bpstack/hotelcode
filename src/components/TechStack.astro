---
const frontend = [
  { name: 'Next.js 16', role: 'Framework' },
  { name: 'React 19', role: 'UI' },
  { name: 'TypeScript', role: 'Tipos' },
  { name: 'Tailwind CSS', role: 'Estilos' },
  { name: 'Zustand', role: 'Estado' },
  { name: 'TanStack Query', role: 'Data fetching' },
];

const backend = [
  { name: 'Express 5', role: 'API' },
  { name: 'MySQL 8', role: 'Base de datos' },
  { name: 'TypeScript', role: 'Tipos' },
  { name: 'Zod', role: 'Validación' },
  { name: 'Cloudinary', role: 'Media' },
  { name: 'Nodemailer', role: 'Email' },
];
---

<section id="tech" class="py-24 sm:py-32 bg-white dark:bg-dark-bg">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-surface-900 dark:text-dark-text">
        Stack tecnológico
      </h2>
      <p class="mt-4 text-lg text-surface-500 dark:text-dark-text2">
        Tecnologías modernas y probadas en producción. Sin sobreingeniería.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <!-- Frontend -->
      <div class="p-6 rounded-2xl border border-surface-200 dark:border-dark-border bg-surface-50 dark:bg-dark-layer1">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-bold text-surface-900 dark:text-dark-text">Frontend</h3>
        </div>
        <div class="space-y-3">
          {frontend.map((tech) => (
            <div class="flex items-center justify-between py-2 px-3 rounded-lg bg-white dark:bg-dark-layer2">
              <span class="font-semibold text-sm text-surface-800 dark:text-dark-text">{tech.name}</span>
              <span class="text-xs text-surface-400 dark:text-dark-text3">{tech.role}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Backend -->
      <div class="p-6 rounded-2xl border border-surface-200 dark:border-dark-border bg-surface-50 dark:bg-dark-layer1">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-8 rounded-lg bg-dark-layer1 dark:bg-dark-layer3 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
            </svg>
          </div>
          <h3 class="font-bold text-surface-900 dark:text-dark-text">Backend</h3>
        </div>
        <div class="space-y-3">
          {backend.map((tech) => (
            <div class="flex items-center justify-between py-2 px-3 rounded-lg bg-white dark:bg-dark-layer2">
              <span class="font-semibold text-sm text-surface-800 dark:text-dark-text">{tech.name}</span>
              <span class="text-xs text-surface-400 dark:text-dark-text3">{tech.role}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
