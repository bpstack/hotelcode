---
const frontend = [
  { name: 'Next.js 16', role: 'Framework', color: 'bg-black dark:bg-white text-white dark:text-black' },
  { name: 'React 19', role: 'UI', color: 'bg-sky-500 text-white' },
  { name: 'TypeScript', role: 'Tipos', color: 'bg-blue-600 text-white' },
  { name: 'Tailwind CSS', role: 'Estilos', color: 'bg-cyan-500 text-white' },
  { name: 'Zustand', role: 'Estado', color: 'bg-amber-600 text-white' },
  { name: 'TanStack Query', role: 'Data fetching', color: 'bg-red-500 text-white' },
];

const backend = [
  { name: 'Express 5', role: 'API', color: 'bg-surface-800 dark:bg-surface-200 text-white dark:text-surface-900' },
  { name: 'MySQL 8', role: 'Base de datos', color: 'bg-blue-800 text-white' },
  { name: 'TypeScript', role: 'Tipos', color: 'bg-blue-600 text-white' },
  { name: 'Zod', role: 'Validación', color: 'bg-indigo-600 text-white' },
  { name: 'Cloudinary', role: 'Media', color: 'bg-purple-600 text-white' },
  { name: 'Nodemailer', role: 'Email', color: 'bg-green-600 text-white' },
];
---

<section id="tech" class="py-24 sm:py-32 bg-white dark:bg-dark-bg relative overflow-hidden">
  <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-brand-500/[0.03] dark:bg-brand-500/[0.02] rounded-full blur-[100px]"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="max-w-3xl mx-auto text-center mb-16">
      <div class="reveal">
        <div class="inline-flex items-center gap-3 font-mono text-sm mb-5">
          <span class="text-brand-500 dark:text-brand-400 font-bold">03</span>
          <span class="w-8 h-px bg-surface-300 dark:bg-dark-layer3"></span>
          <span class="text-surface-400 dark:text-dark-text3 tracking-wide">// stack</span>
        </div>
      </div>
      <h2 class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-surface-900 dark:text-dark-text leading-tight">
        Stack <span class="bg-gradient-to-r from-brand-500 to-brand-700 dark:from-brand-300 dark:to-brand-500 bg-clip-text text-transparent">tecnológico</span>
      </h2>
      <p class="reveal mt-5 text-lg text-surface-500 dark:text-dark-text2 max-w-2xl mx-auto">
        Tecnologías modernas y probadas en producción. Sin sobreingeniería.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      <!-- Frontend -->
      <div data-glow class="reveal reveal-delay-1 group p-6 sm:p-7 rounded-2xl border border-surface-200/80 dark:border-dark-border/80 bg-gradient-to-b from-surface-50 to-white dark:from-dark-layer1 dark:to-dark-layer1 hover:shadow-xl hover:shadow-surface-900/[0.04] dark:hover:shadow-black/10 transition-all duration-500 hover:-translate-y-0.5">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center shadow-md shadow-brand-500/20">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-surface-900 dark:text-dark-text">Frontend</h3>
            <p class="text-xs text-surface-500 dark:text-dark-text2">Interfaz de usuario</p>
          </div>
        </div>
        <div class="space-y-2.5">
          {frontend.map((tech) => (
            <div class="flex items-center justify-between py-2.5 px-4 rounded-xl bg-white dark:bg-dark-layer2 border border-surface-100 dark:border-dark-border/50 hover:border-surface-200 dark:hover:border-dark-layer3 transition-colors group/item">
              <div class="flex items-center gap-3">
                <span class={`w-2 h-2 rounded-full ${tech.color}`}></span>
                <span class="font-semibold text-sm text-surface-800 dark:text-dark-text">{tech.name}</span>
              </div>
              <span class="text-xs font-medium text-surface-500 dark:text-dark-text2 px-2 py-0.5 rounded-md bg-surface-50 dark:bg-dark-layer1">{tech.role}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Backend -->
      <div data-glow class="reveal reveal-delay-2 group p-6 sm:p-7 rounded-2xl border border-surface-200/80 dark:border-dark-border/80 bg-gradient-to-b from-surface-50 to-white dark:from-dark-layer1 dark:to-dark-layer1 hover:shadow-xl hover:shadow-surface-900/[0.04] dark:hover:shadow-black/10 transition-all duration-500 hover:-translate-y-0.5">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-surface-700 to-surface-900 dark:from-dark-layer3 dark:to-dark-layer2 flex items-center justify-center shadow-md shadow-surface-900/20">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white dark:text-dark-text" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-surface-900 dark:text-dark-text">Backend</h3>
            <p class="text-xs text-surface-500 dark:text-dark-text2">API y base de datos</p>
          </div>
        </div>
        <div class="space-y-2.5">
          {backend.map((tech) => (
            <div class="flex items-center justify-between py-2.5 px-4 rounded-xl bg-white dark:bg-dark-layer2 border border-surface-100 dark:border-dark-border/50 hover:border-surface-200 dark:hover:border-dark-layer3 transition-colors group/item">
              <div class="flex items-center gap-3">
                <span class={`w-2 h-2 rounded-full ${tech.color}`}></span>
                <span class="font-semibold text-sm text-surface-800 dark:text-dark-text">{tech.name}</span>
              </div>
              <span class="text-xs font-medium text-surface-500 dark:text-dark-text2 px-2 py-0.5 rounded-md bg-surface-50 dark:bg-dark-layer1">{tech.role}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
