---

<section id="modulos" class="py-24 sm:py-32 bg-surface-50/50 dark:bg-dark-layer1/50 relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--color-brand-50)_0%,_transparent_60%)] dark:bg-[radial-gradient(ellipse_at_center,_var(--color-dark-layer2)_0%,_transparent_60%)] opacity-50"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="max-w-3xl mx-auto text-center mb-16">
      <div class="reveal">
        <div class="inline-flex items-center gap-3 font-mono text-sm mb-5">
          <span class="text-brand-500 dark:text-brand-400 font-bold">02</span>
          <span class="w-8 h-px bg-surface-300 dark:bg-dark-layer3"></span>
          <span class="text-surface-400 dark:text-dark-text3 tracking-wide">// módulos</span>
        </div>
      </div>
      <h2 class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-surface-900 dark:text-dark-text leading-tight">
        +14 módulos, <br class="hidden sm:block" />
        <span class="bg-gradient-to-r from-brand-500 to-brand-700 dark:from-brand-300 dark:to-brand-500 bg-clip-text text-transparent">un solo sistema</span>
      </h2>
      <p class="reveal mt-5 text-lg text-surface-500 dark:text-dark-text2 max-w-2xl mx-auto">
        Cada módulo resuelve un problema operativo real. No son features inventadas:
        son herramientas que yo necesitaba en mi día a día.
      </p>
    </div>

    <!-- Module cards — bento-style grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {modules.map((mod, i) => (
        <div data-glow class={`reveal reveal-delay-${i + 1} group relative p-5 rounded-2xl bg-white ${mod.cardDark} border border-surface-200/80 hover:border-surface-300/80 hover:shadow-lg shadow-surface-900/[0.03] dark:shadow-black/10 transition-all duration-500 hover:-translate-y-1 overflow-hidden`}>
          <!-- Top gradient accent line -->
          <div class={`absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r ${mod.accent} opacity-0 group-hover:opacity-100 transition-opacity duration-500`}></div>

          <div class={`w-10 h-10 rounded-xl ${mod.accentBg} flex items-center justify-center mb-3 transition-transform duration-500 group-hover:scale-110`}>
            <svg xmlns="http://www.w3.org/2000/svg" class={`w-5 h-5 ${mod.iconColor}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={icons[mod.icon]} />
            </svg>
          </div>
          <h3 class="font-bold text-surface-900 dark:text-dark-text mb-1.5">{mod.name}</h3>
          <p class="text-sm text-surface-500 dark:text-dark-text2 leading-relaxed">{mod.desc}</p>
        </div>
      ))}
    </div>

    <!-- Additional modules note -->
    <div class="reveal mt-10 text-center">
      <div class="inline-flex items-center gap-3 px-5 py-3 rounded-2xl bg-white dark:bg-dark-layer2 border border-surface-200/60 dark:border-dark-border/60 shadow-sm">
        <span class="flex items-center justify-center w-6 h-6 rounded-full bg-brand-50 dark:bg-brand-900/20 text-xs font-bold text-brand-600 dark:text-brand-400">+</span>
        <span class="text-sm text-surface-500 dark:text-dark-text2">
          Blacklist, Conciliación, Backoffice, Notificaciones, Activity Log, Departamentos...
        </span>
      </div>
    </div>
  </div>
</section>
