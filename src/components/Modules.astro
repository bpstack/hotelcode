    iconColor: 'text-cyan-600 dark:text-cyan-400',
    cardDark: 'dark:bg-cyan-950/30 dark:border-cyan-900/40 dark:hover:border-cyan-700/50',
  },
  {
    name: 'Messaging',
    desc: 'Comunicación interna directa y grupal entre departamentos',
    icon: 'message',
    accent: 'from-pink-500 to-pink-600',
    accentBg: 'bg-pink-50 dark:bg-pink-500/10',
