    accentBg: 'bg-orange-50 dark:bg-orange-500/10',
    iconColor: 'text-orange-600 dark:text-orange-400',
    cardDark: 'dark:bg-orange-950/30 dark:border-orange-900/40 dark:hover:border-orange-700/50',
  },
  {
    name: 'Groups',
