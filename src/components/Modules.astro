---
const modules = [
  {
    name: 'Dashboard',
    desc: 'KPIs en tiempo real, alertas críticas y feed de actividad del hotel',
    icon: 'chart',
  },
  {
    name: 'Scheduling',
    desc: 'Turnos de recepción con validación automática de restricciones laborales',
    icon: 'calendar',
  },
  {
    name: 'Logbooks',
    desc: 'Libro de consigna digital entre turnos con prioridades, comentarios y seguimiento',
    icon: 'book',
  },
  {
    name: 'Parking',
    desc: 'Gestión de plazas, reservas, check-in/out y analytics de ocupación',
    icon: 'car',
  },
  {
    name: 'Cashier',
    desc: 'Caja diaria por turnos, arqueo, pagos electrónicos y reportes',
    icon: 'cash',
  },
  {
    name: 'Maintenance',
    desc: 'Órdenes de trabajo con estados, asignación y seguimiento fotográfico',
    icon: 'wrench',
  },
  {
    name: 'Groups',
    desc: 'Reservas de grupo con contactos, habitaciones, pagos y auditoría',
    icon: 'users',
  },
  {
    name: 'Messaging',
    desc: 'Comunicación interna directa y grupal entre departamentos',
    icon: 'message',
  },
];

