---
import ThemeToggle from './ThemeToggle.astro';
---

<nav id="main-nav" class="fixed top-4 left-0 right-0 z-50 transition-all duration-500">
  <div class="max-w-5xl mx-auto px-4">
    <div class="flex items-center justify-between h-14 px-4 sm:px-6 rounded-2xl bg-white/70 dark:bg-dark-layer1/70 backdrop-blur-xl border border-surface-200/50 dark:border-dark-border/50 shadow-lg shadow-surface-900/[0.03] dark:shadow-black/20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group shrink-0 px-2 py-1 rounded-xl transition-all duration-300 hover:-translate-y-0.5">
        <svg width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg" class="logo-svg w-9 h-9 shrink-0">
          <defs>
            <linearGradient id="logobg" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#4338ca"/>
              <stop offset="100%" stop-color="#7c3aed"/>
            </linearGradient>
          </defs>
          <!-- Hexagon fill -->
          <path d="M19 2 L33.5 10.5 L33.5 27.5 L19 36 L4.5 27.5 L4.5 10.5 Z" fill="url(#logobg)"/>
          <!-- HC text -->
          <text x="19" y="24" text-anchor="middle" font-family="system-ui, sans-serif" font-size="13" font-weight="700" fill="white" letter-spacing="-0.5">HC</text>
          <!-- Underline trace -->
          <line class="logo-trace" x1="13" y1="27" x2="25" y2="27" stroke="white" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        <span class="text-lg font-bold text-surface-900 dark:text-dark-text hidden sm:block">
          Hotel<span class="text-brand-600 dark:text-brand-400">Code</span>
        </span>
      </a>

      <style>
        .logo-trace {
          stroke-dasharray: 12;
          stroke-dashoffset: 12;
          transition: stroke-dashoffset 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }
        a:hover .logo-trace {
          stroke-dashoffset: 0;
        }
        .logo-svg {
          transition: filter 0.4s ease;
        }
        a:hover .logo-svg {
          filter: drop-shadow(0 0 8px rgba(139, 92, 246, 0.6));
        }
      </style>

      <!-- Nav links — pill style -->
      <div class="hidden md:flex items-center gap-1 text-sm font-semibold">
        <a href="#proyecto" class="px-4 py-1.5 rounded-full text-surface-500 dark:text-dark-text2 hover:text-surface-900 dark:hover:text-dark-text hover:bg-surface-100 dark:hover:bg-dark-layer2 transition-all duration-200">
          Proyecto
        </a>
        <a href="#modulos" class="px-4 py-1.5 rounded-full text-surface-500 dark:text-dark-text2 hover:text-surface-900 dark:hover:text-dark-text hover:bg-surface-100 dark:hover:bg-dark-layer2 transition-all duration-200">
          Módulos
        </a>
        <a href="#tech" class="px-4 py-1.5 rounded-full text-surface-500 dark:text-dark-text2 hover:text-surface-900 dark:hover:text-dark-text hover:bg-surface-100 dark:hover:bg-dark-layer2 transition-all duration-200">
          Tech
        </a>
        <a href="#sobre-mi" class="px-4 py-1.5 rounded-full text-surface-500 dark:text-dark-text2 hover:text-surface-900 dark:hover:text-dark-text hover:bg-surface-100 dark:hover:bg-dark-layer2 transition-all duration-200">
          Sobre mí
        </a>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-2">
        <ThemeToggle />

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          type="button"
          aria-label="Menú"
          class="md:hidden w-9 h-9 rounded-lg flex items-center justify-center text-surface-500 hover:text-surface-700 dark:text-dark-text3 dark:hover:text-dark-text hover:bg-surface-100 dark:hover:bg-dark-layer2 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            <path id="menu-icon-close" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" class="hidden" />
          </svg>
        </button>

        <a
          href="https://four-points.stackbp.es"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:inline-flex items-center gap-1.5 px-4 py-2 text-sm font-semibold text-white bg-gradient-to-r from-brand-600 to-brand-700 rounded-xl hover:from-brand-500 hover:to-brand-600 shadow-md shadow-brand-600/20 hover:shadow-brand-500/30 transition-all duration-300 hover:-translate-y-0.5"
        >
          Ver demo
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Mobile menu dropdown -->
    <div id="mobile-menu" class="hidden md:hidden mt-2 rounded-2xl bg-white/90 dark:bg-dark-layer1/90 backdrop-blur-xl border border-surface-200/50 dark:border-dark-border/50 shadow-lg overflow-hidden">
      <div class="py-3 px-4 space-y-1">
        <a href="#proyecto" class="block px-4 py-2.5 rounded-xl text-sm font-semibold text-surface-600 dark:text-dark-text2 hover:bg-surface-100 dark:hover:bg-dark-layer2 transition-colors">Proyecto</a>
        <a href="#modulos" class="block px-4 py-2.5 rounded-xl text-sm font-semibold text-surface-600 dark:text-dark-text2 hover:bg-surface-100 dark:hover:bg-dark-layer2 transition-colors">Módulos</a>
        <a href="#tech" class="block px-4 py-2.5 rounded-xl text-sm font-semibold text-surface-600 dark:text-dark-text2 hover:bg-surface-100 dark:hover:bg-dark-layer2 transition-colors">Tech</a>
        <a href="#sobre-mi" class="block px-4 py-2.5 rounded-xl text-sm font-semibold text-surface-600 dark:text-dark-text2 hover:bg-surface-100 dark:hover:bg-dark-layer2 transition-colors">Sobre mí</a>
        <a href="https://four-points.stackbp.es" target="_blank" rel="noopener noreferrer" class="block px-4 py-2.5 rounded-xl text-sm font-semibold text-brand-600 dark:text-brand-400 hover:bg-brand-50 dark:hover:bg-brand-900/20 transition-colors sm:hidden">Ver demo live →</a>
      </div>
    </div>
  </div>
</nav>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');
    if (!btn || !menu) return;

    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      iconOpen?.classList.toggle('hidden', !isOpen);
      iconClose?.classList.toggle('hidden', isOpen);
    });

    // Close on link click
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        iconOpen?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
      });
    });
  }

  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
