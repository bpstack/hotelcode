              GitHub
            </a>
            <a
              href="https://stackbp.es"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-surface-700 dark:text-dark-text bg-white dark:bg-dark-layer2 border border-surface-200 dark:border-dark-border rounded-lg hover:border-surface-300 dark:hover:border-dark-layer3 hover:bg-surface-50 dark:hover:bg-dark-layer3 transition-colors"
