---
---

<section id="proyecto" class="py-24 sm:py-32 bg-white dark:bg-dark-bg relative overflow-hidden">
  <!-- Section background accent -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-brand-500/[0.03] dark:bg-brand-500/[0.02] rounded-full blur-[100px]"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="max-w-3xl mx-auto text-center mb-16">
      <div class="reveal">
        <div class="inline-flex items-center gap-3 font-mono text-sm mb-5">
          <span class="text-brand-500 dark:text-brand-400 font-bold">01</span>
          <span class="w-8 h-px bg-surface-300 dark:bg-dark-layer3"></span>
          <span class="text-surface-400 dark:text-dark-text3 tracking-wide">// el_proyecto</span>
        </div>
      </div>
      <h2 class="reveal text-3xl sm:text-4xl lg:text-5xl font-bold text-surface-900 dark:text-dark-text leading-tight">
        Un PMS construido <br class="hidden sm:block" />
        <span class="bg-gradient-to-r from-brand-500 to-brand-700 dark:from-brand-300 dark:to-brand-500 bg-clip-text text-transparent">desde la operación real</span>
      </h2>
      <p class="reveal mt-5 text-lg text-surface-500 dark:text-dark-text2 leading-relaxed max-w-2xl mx-auto">
        Más de 10 años en recepción de hotel. Conocí cada dolor operativo.
        Cuando aprendí a programar, decidí resolverlos todos.
      </p>
    </div>

    <!-- Feature cards — 3-column grid with glow hover -->
    <div class="grid md:grid-cols-3 gap-5">
      <!-- Card 1 -->
      <div data-glow class="reveal reveal-delay-1 group relative p-7 rounded-2xl border border-surface-200/80 dark:border-dark-border/80 bg-white dark:bg-dark-layer1 hover:border-brand-300/60 dark:hover:border-brand-600/40 hover:shadow-xl hover:shadow-brand-500/[0.04] dark:hover:shadow-brand-500/[0.02] transition-all duration-500 hover:-translate-y-1">
        <!-- Icon badge -->
        <div class="relative z-2 w-12 h-12 rounded-2xl bg-gradient-to-br from-brand-50 to-brand-100 dark:from-brand-900/20 dark:to-brand-800/10 flex items-center justify-center mb-5 shadow-sm group-hover:shadow-md group-hover:shadow-brand-500/10 transition-all duration-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brand-600 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
        </div>
        <h3 class="relative z-2 text-lg font-bold text-surface-900 dark:text-dark-text mb-2">Problema real</h3>
        <p class="text-surface-500 dark:text-dark-text2 text-sm leading-relaxed">
          Hojas de cálculo, WhatsApp, papeles sueltos. La operación diaria de un hotel
          depende de herramientas que no fueron diseñadas para eso.
        </p>
        <!-- Arrow link hint -->
        <div class="mt-5 flex items-center gap-1.5 text-xs font-semibold text-brand-500 dark:text-brand-400 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
          El dolor que motivó todo
          <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        </div>
      </div>

      <!-- Card 2 -->
      <div data-glow class="reveal reveal-delay-2 group relative p-7 rounded-2xl border border-surface-200/80 dark:border-dark-border/80 bg-white dark:bg-dark-layer1 hover:border-brand-300/60 dark:hover:border-brand-600/40 hover:shadow-xl hover:shadow-brand-500/[0.04] dark:hover:shadow-brand-500/[0.02] transition-all duration-500 hover:-translate-y-1">
        <div class="relative z-2 w-12 h-12 rounded-2xl bg-gradient-to-br from-brand-50 to-brand-100 dark:from-brand-900/20 dark:to-brand-800/10 flex items-center justify-center mb-5 shadow-sm group-hover:shadow-md group-hover:shadow-brand-500/10 transition-all duration-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brand-600 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
        </div>
        <h3 class="relative z-2 text-lg font-bold text-surface-900 dark:text-dark-text mb-2">Solución con código</h3>
        <p class="text-surface-500 dark:text-dark-text2 text-sm leading-relaxed">
          Un sistema centralizado que reemplaza Excel, los grupos de WhatsApp
          y los cuadernos de notas por módulos digitales integrados.
        </p>
        <div class="mt-5 flex items-center gap-1.5 text-xs font-semibold text-brand-500 dark:text-brand-400 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
          Stack moderno, resultado real
          <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        </div>
      </div>

      <!-- Card 3 -->
      <div data-glow class="reveal reveal-delay-3 group relative p-7 rounded-2xl border border-surface-200/80 dark:border-dark-border/80 bg-white dark:bg-dark-layer1 hover:border-brand-300/60 dark:hover:border-brand-600/40 hover:shadow-xl hover:shadow-brand-500/[0.04] dark:hover:shadow-brand-500/[0.02] transition-all duration-500 hover:-translate-y-1">
        <div class="relative z-2 w-12 h-12 rounded-2xl bg-gradient-to-br from-brand-50 to-brand-100 dark:from-brand-900/20 dark:to-brand-800/10 flex items-center justify-center mb-5 shadow-sm group-hover:shadow-md group-hover:shadow-brand-500/10 transition-all duration-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brand-600 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="relative z-2 text-lg font-bold text-surface-900 dark:text-dark-text mb-2">Documentado aquí</h3>
        <p class="text-surface-500 dark:text-dark-text2 text-sm leading-relaxed">
          Cada decisión técnica, cada error, cada solución. No es un tutorial genérico:
          es el diario de construcción de un producto real.
        </p>
        <div class="mt-5 flex items-center gap-1.5 text-xs font-semibold text-brand-500 dark:text-brand-400 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
          Transparencia total
          <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        </div>
      </div>
    </div>

    <!-- Stats strip -->
    <div class="reveal mt-16 grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-3xl mx-auto">
      <div class="text-center p-5 rounded-2xl bg-surface-50 dark:bg-dark-layer1 border border-surface-200/60 dark:border-dark-border/60">
        <div class="text-2xl sm:text-3xl font-bold text-surface-900 dark:text-dark-text">+14</div>
        <div class="text-xs font-semibold text-surface-400 dark:text-dark-text3 mt-1 uppercase tracking-wide">Módulos</div>
      </div>
      <div class="text-center p-5 rounded-2xl bg-surface-50 dark:bg-dark-layer1 border border-surface-200/60 dark:border-dark-border/60">
        <div class="text-2xl sm:text-3xl font-bold text-surface-900 dark:text-dark-text">+40</div>
        <div class="text-xs font-semibold text-surface-400 dark:text-dark-text3 mt-1 uppercase tracking-wide">Tablas DB</div>
      </div>
      <div class="text-center p-5 rounded-2xl bg-surface-50 dark:bg-dark-layer1 border border-surface-200/60 dark:border-dark-border/60">
        <div class="text-2xl sm:text-3xl font-bold text-surface-900 dark:text-dark-text">Full</div>
        <div class="text-xs font-semibold text-surface-400 dark:text-dark-text3 mt-1 uppercase tracking-wide">Stack</div>
      </div>
      <div class="text-center p-5 rounded-2xl bg-surface-50 dark:bg-dark-layer1 border border-surface-200/60 dark:border-dark-border/60">
        <div class="text-2xl sm:text-3xl font-bold text-surface-900 dark:text-dark-text">100%</div>
        <div class="text-xs font-semibold text-surface-400 dark:text-dark-text3 mt-1 uppercase tracking-wide">Open Source</div>
      </div>
    </div>
  </div>
</section>
